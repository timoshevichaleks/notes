    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.28",
    "@angular/cli": "^20.3.28",
    "@angular/compiler-cli": "^20.3.0",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "^20.7.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
